# Connection string Postgres (Supabase), région EU.
# Utiliser le POOLER en mode SESSION (port 5432) : fiable avec postgres-js en
# local ET en serverless (le mode transaction 6543 bloque sur la 1re requête).
# Encoder le mot de passe en pourcent si caractères spéciaux (/ # ! ? → %2F %23 %21 %3F).
#   DATABASE_URL=postgresql://postgres.<ref>:<motdepasse>@aws-0-eu-west-1.pooler.supabase.com:5432/postgres
DATABASE_URL=

# Mettre "disable" uniquement pour un Postgres local sans SSL. Par défaut : SSL requis.
# DATABASE_SSL=disable
